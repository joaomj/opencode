{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "https://raw.githubusercontent.com/joaomj/skills/main/AGENTS.md"
  ],
  "autoupdate": true,
  "permission": {
    "bash": {
      "*": "allow",
      "git *": "ask",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "npm *": "ask",
      "rm *": "ask",
      "ssh *": "ask",
      "brew *": "ask",
      "cat .env *": "deny",
      "docker *": "ask"
    },
    "skill": {
      "*": "allow"
    }
  },
  "small_model": "openai/gpt-5-nano",
  "agent": {
    "code-review": {
      "mode": "primary",
      "model": "openai/gpt-5.3-codex",
      "temperature": 0.1,
      "reasoningEffort": "high",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      },
      "permission": {
        "task": {
          "*": "deny",
          "code-reviewer-*": "allow"
        },
        "bash": {
          "git *": "allow"
        }
      }
    },
    "code-reviewer-1": {
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex",
      "temperature": 0.1,
      "reasoningEffort": "high",
      "hidden": true,
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      },
      "permission": {
        "bash": {
          "git *": "allow"
        }
      }
    },
    "code-reviewer-2": {
      "mode": "subagent",
      "model": "opencode/claude-opus-4.5",
      "fallbackModel": "zai/glm-4.7",
      "temperature": 0.1,
      "hidden": true,
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      },
      "permission": {
        "bash": {
          "git *": "allow"
        }
      }
    }
  },
  "provider": {
    "openai": {
      "models": {
        "gpt-5.3-codex": {
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "low"
          }
        }
      }
    },
    "opencode": {
      "models": {
        "minimax-m2.5-free": {},
        "claude-opus-4.5": {}
      }
    }
  }
}
