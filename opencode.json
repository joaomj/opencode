{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "https://raw.githubusercontent.com/joaomj/skills/main/AGENTS.md"
  ],
  "autoupdate": true,
  "permission": {
    "bash": {
      "*": "allow",
      "git *": "ask",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "npm *": "ask",
      "rm *": "ask",
      "ssh *": "ask",
      "brew *": "ask",
      "cat .env *": "deny",
      "* .env *": "deny",
      "docker *": "ask"
    },
    "skill": {
      "*": "allow"
    }
  },
  "small_model": "openai/gpt-5.1-codex-mini",
  "agent": {
    "code-reviewer-1": {
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex",
      "temperature": 0.1,
      "reasoningEffort": "high",
      "hidden": true,
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      },
      "permission": {
        "bash": {
          "git *": "allow"
        }
      }
    },
    "code-reviewer-2": {
      "mode": "subagent",
      "model": "zai/glm-4.7",
      "temperature": 0.1,
      "hidden": true,
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      },
      "permission": {
        "bash": {
          "git *": "allow"
        }
      }
    }
  },
  "provider": {
    "lmstudio-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": { "baseURL": "http://127.0.0.1:1234/v1" },
      "models": {
        "qwen3.5-9b-mlx": { "name": "Qwen3.5-9B MLX (local)" }
      }
    }
  }
}
